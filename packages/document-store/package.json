{
  "name": "@cisco_open/linting-document-store",
  "version": "1.0.0-rc.4",
  "description": "Pluggable document storage library for API specifications. Used by the linting orchestrator and the MCP analysis server.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cisco-open/linting-orchestrator.git",
    "directory": "packages/document-store"
  },
  "homepage": "https://github.com/cisco-open/linting-orchestrator/tree/main/packages/document-store#readme",
  "bugs": {
    "url": "https://github.com/cisco-open/linting-orchestrator/issues"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/index.js",
      "types": "./build/index.d.ts"
    },
    "./interfaces": {
      "import": "./build/interfaces/index.js",
      "types": "./build/interfaces/index.d.ts"
    },
    "./adapters/local": {
      "import": "./build/adapters/local-document-store.js",
      "types": "./build/adapters/local-document-store.d.ts"
    },
    "./adapters/mcp": {
      "import": "./build/adapters/mcp-document-store.js",
      "types": "./build/adapters/mcp-document-store.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf build"
  },
  "keywords": [
    "linting",
    "document-storage",
    "pluggable",
    "adapter",
    "mcp"
  ],
  "author": "Cisco Systems, Inc.",
  "contributors": [
    "DevNet Team"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "build",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}