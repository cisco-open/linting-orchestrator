# Orchestrator daemon (spectifyd) configuration
# Copy to .env in the directory where you run spectifyd and adjust as needed.
# All variables are optional — commented defaults are shown.

# ============================================
# DATA DIRECTORY
# ============================================

# Base directory for all Spectify runtime data.
# Overrides ~/.spectify for uploads, reports queue, and CLI config.
# Useful for containers (mount a volume here) or multi-instance setups.
# SPECTIFY_HOME=~/.spectify

# ============================================
# SERVER
# ============================================

# SPECTIFYD_PORT=3003
# SPECTIFYD_HOST=0.0.0.0

# ============================================
# DOCUMENT STORE
# ============================================

# SPECTIFYD_DOCUMENT_STORE_TYPE=local          # local | passthrough
# SPECTIFYD_DOCUMENT_STORE_DIR=                # default: $SPECTIFY_HOME/uploads
# SPECTIFYD_DOCUMENT_STORE_FALLBACK_HTTP=http://localhost:3002

# ============================================
# WORKER POOL
# ============================================

# SPECTIFYD_MIN_WORKERS_PER_RULESET=1
# SPECTIFYD_MAX_WORKERS_PER_RULESET=2
# SPECTIFYD_TOTAL_MAX_WORKERS=15               # auto-detected from CPU count if not set
# SPECTIFYD_WORKER_TIMEOUT=30000               # ms
# SPECTIFYD_WORKER_WAIT_TIMEOUT=30000          # ms
# SPECTIFYD_DOCUMENT_CACHE_ENABLED=true

# ============================================
# STORAGE BACKEND
# ============================================

# SPECTIFYD_STORAGE_TYPE=memory                # memory | redis
# SPECTIFYD_REDIS_URL=redis://localhost:6379

# ============================================
# LOGGING
# ============================================

# SPECTIFYD_LOG_LEVEL=info                     # debug | info | warn | error
# SPECTIFYD_LOG_FORMAT=json                    # json | pretty

# ============================================
# RULESETS
# ============================================

# SPECTIFYD_RULESETS_DIR=                      # override bundled rulesets path

# ============================================
# REPORTS SERVICE INTEGRATION (optional audit trail)
# ============================================

# Enable report delivery to spectifyr (disabled by default).
# SPECTIFYD_REPORTS_ENABLED=false

# SPECTIFYD_REPORTS_URL=http://localhost:3010

# SPECTIFYD_REPORTS_API_KEY is a secret — do not store it in this file.
# Set it via environment or a secrets manager:
#   export SPECTIFYD_REPORTS_API_KEY=$(cat /run/secrets/spectifyr_key)

# SPECTIFYD_REPORTS_STOP_IF_UNAVAILABLE=false
# SPECTIFYD_REPORTS_PENDING_DIR=               # default: $SPECTIFY_HOME/reports/pending
# SPECTIFYD_REPORTS_TIMEOUT=5000               # ms
# SPECTIFYD_REPORTS_MAX_RETRIES=3
# SPECTIFYD_REPORTS_BASE_RETRY_DELAY=1000      # ms
# SPECTIFYD_REPORTS_RETRY_JOB_ENABLED=true
# SPECTIFYD_REPORTS_RETRY_JOB_INTERVAL=300000  # ms (5 minutes)
