{
  "name": "@cisco_open/linting-reports",
  "version": "1.0.0-rc.5",
  "clientVersion": "1.6.0",
  "description": "Persistent storage and web UI for lint job results. The linting reporting service (spectifyr) receives notifications from the linting orchestrator, stores them in SQLite, and exposes a browsable web UI.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "spectifyr": "build/index.js"
  },
  "exports": {
    ".": "./build/index.js",
    "./client": "./build/client/index.js",
    "./types": "./build/types.js"
  },
  "scripts": {
    "build": "tsc && npm run copy:templates && npm run copy:schema && chmod 755 build/index.js",
    "copy:templates": "mkdir -p build/templates && cp -r src/templates/* build/templates/",
    "copy:schema": "mkdir -p build/schema && cp schema/schema.sql build/schema/",
    "dev": "NODE_ENV=development tsx src/index.ts",
    "start": "DOTENV_CONFIG_QUIET=true NODE_ENV=production SPECTIFYR_DB_PATH=~/.spectify/reports/database/reports.db node build/index.js",
    "start:prod": "npm start",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest watch",
    "lint": "eslint src --ext .ts",
    "cleanup": "tsx src/cleanup/cleanup.ts",
    "reset": "rm -f ${DATABASE_PATH:-./reports.db} && echo '✅ Database reset complete. The database will be recreated on next server start.'",
    "example": "tsx examples/client-usage.ts"
  },
  "keywords": [
    "linting",
    "reports",
    "api",
    "spectral"
  ],
  "author": "Cisco Systems, Inc. and its affiliates",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/cisco-open/linting-orchestrator.git",
    "directory": "packages/reports"
  },
  "homepage": "https://github.com/cisco-open/linting-orchestrator/tree/main/packages/reports#readme",
  "bugs": {
    "url": "https://github.com/cisco-open/linting-orchestrator/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@fastify/static": "^7.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^17.2.3",
    "fastify": "^5.7.4",
    "handlebars": "^4.7.8",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "semver": "^7.7.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^8.57.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^4.0.18"
  },
  "files": [
    "build",
    "schema",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}