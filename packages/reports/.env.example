# Report Service Configuration
# Copy to .env in the directory where you run spectifyr and customize.

# ============================================
# REQUIRED
# ============================================

# API key for authentication (shared with the linting orchestrator service).
# This is a secret — do not store it in this file.
# Generate: openssl rand -hex 32
# Set via environment or secrets manager:
#   export SPECTIFYR_API_KEY=$(cat /run/secrets/spectifyr_key)

# ============================================
# DATA DIRECTORY
# ============================================

# Base directory for all Spectify runtime data (mirrors spectifyd).
# SPECTIFY_HOME=~/.spectify

# ============================================
# SERVER (Optional - defaults shown)
# ============================================

SPECTIFYR_PORT=3010
SPECTIFYR_HOST=0.0.0.0

# ============================================
# DATABASE (Optional)
# ============================================

# Default: $SPECTIFY_HOME/reports/database/reports.db
# SPECTIFYR_DB_PATH=

# ============================================
# LOGGING (Optional - defaults shown)
# ============================================

LOG_LEVEL=info              # debug, info, warn, error
LOG_FORMAT=pretty           # 'pretty' (human-readable) or 'json' (structured)

# ============================================
# QUEUED NOTIFICATIONS (Optional)
# ============================================

# Pending notifications (written when report delivery fails temporarily).
# Default: $SPECTIFY_HOME/reports/pending
# SPECTIFYR_PENDING_DIR=

# Dead-letter notifications (permanently failed after all retries).
# Default: $SPECTIFY_HOME/reports/dead-letter
# SPECTIFYR_DEAD_LETTER_DIR=
